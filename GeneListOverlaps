#Plot with manual odds ratio definition#

# ---- Define Odds Ratios ----
OR_values <- c(
  male_male    = NA,   # void tile
  male_female  = 7.1,
  male_sfari   = 1.2,
  female_sfari = 2.7
)

# ---- Construct plotting dataframe ----
plot_df <- data.frame(
  Set1 = factor(c("Male DMR", "Female DMR",
                  "Male DMR", "Female DMR"),
                levels = c("Male DMR", "Female DMR")),
  
  Set2 = factor(c("Male DMR", "Male DMR",
                  "SFARI Gene", "SFARI Gene"),
                levels = c("Male DMR", "SFARI Gene")),
  
  Overlap = c(male_male, male_female,
              male_sfari, female_sfari),
  
  OR = c(OR_values["male_male"],
         OR_values["male_female"],
         OR_values["male_sfari"],
         OR_values["female_sfari"])
)

# Flag tiles for asterisk
plot_df$asterisk <- ifelse(
  (plot_df$Set1 == "Female DMR" & plot_df$Set2 == "Male DMR") |
    (plot_df$Set1 == "Female DMR" & plot_df$Set2 == "SFARI Gene"),
  "*", ""
)

# Separate Male–Male tile
male_male_tile <- plot_df %>%
  filter(Set1 == "Male DMR" & Set2 == "Male DMR")

heat_tiles <- plot_df %>%
  filter(!(Set1 == "Male DMR" & Set2 == "Male DMR"))

# ---- PLOT ----

p <- ggplot() +
  
  # Heatmap tiles (fill by Odds Ratio)
  geom_tile(
    data = heat_tiles,
    aes(x = Set1, y = Set2, fill = OR),
    color = "black"
  ) +
  
  # Add overlap counts
  geom_text(
    data = heat_tiles,
    aes(x = Set1, y = Set2, label = Overlap),
    size = 5,
    fontface = "bold"
  ) +
  
  # Add asterisks
  geom_text(
    data = heat_tiles %>% filter(asterisk == "*"),
    aes(x = Set1, y = Set2, label = "*"),
    size = 8,
    fontface = "bold",
    vjust = -1
  ) +
  
  # Male–Male void tile
  geom_tile(
    data = male_male_tile,
    aes(x = Set1, y = Set2),
    fill = NA,
    color = "black",
    linewidth = 1
  ) +
  
  # Black X across Male–Male tile
  geom_segment(
    data = male_male_tile,
    aes(x = 1 - 0.5, xend = 1 + 0.5,
        y = 1 - 0.5, yend = 1 + 0.5),
    inherit.aes = FALSE,
    linewidth = 1.2
  ) +
  geom_segment(
    data = male_male_tile,
    aes(x = 1 - 0.5, xend = 1 + 0.5,
        y = 1 + 0.5, yend = 1 - 0.5),
    inherit.aes = FALSE,
    linewidth = 1.2
  ) +
  
  # White → Red gradient based on Odds Ratio
  scale_fill_gradient(
    low = "white",
    high = "red",
    name = "Odds Ratio",
    na.value = "white"
  ) +
  
  labs(
    title = "Gene Set Overlap (Odds Ratio)",
    x = NULL,
    y = NULL
  ) +
  
  coord_fixed() +
  
  theme_minimal(base_size = 14) +
  theme(
    panel.grid = element_blank(),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )

print(p)

