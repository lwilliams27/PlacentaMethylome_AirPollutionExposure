#Module Region GO Enrichment Analysis#

#Analyze Functional Enrichments#
library(rGREAT)
library(GenomicRanges)
library(GenomeInfoDb)
library(IRanges)
library(org.Hs.eg.db)

enrichModule <- function(regions, module = NULL,
                         genome = c("hg38"),
                         ontologies = c("GO:BP", "GO:MF", "GO:CC"),
                         min_region_hits = 2,
                         pvalue_threshold = 0.05,
                         adjMethod = c("fdr", "holm", "hochberg", "hommel",
                                       "bonferroni", "BH", "BY", "none"),
                         save = TRUE, file = "Module_Enrichment_Results.txt",
                         verbose = TRUE) {
  
  # Match arguments
  genome <- match.arg(genome)
  if (genome != "hg38") stop("[enrichModule] Only hg38 supported in local version")
  adjMethod <- match.arg(adjMethod)
  
  # Subset regions by module
  if (!is.null(module)) {
    if (verbose) message("[enrichModule] Analyzing regions in module: ", module)
    moduleRegions <- regions[regions$module %in% module, ]
  } else {
    if (verbose) message("[enrichModule] Analyzing all non-'grey' modules")
    moduleRegions <- regions[regions$module != "grey", ]
  }
  
  # Clean GRanges
  fixGR <- function(gr) {
    gr <- gr[!is.na(start(gr)) & !is.na(end(gr)) & width(gr) > 0]
    gr <- GenomeInfoDb::keepStandardChromosomes(gr, pruning.mode = "coarse")
    GenomeInfoDb::seqlevelsStyle(gr) <- "UCSC"
    gr
  }
  
  # Build GRanges object
  gr <- with(moduleRegions, GenomicRanges::GRanges(chr, IRanges::IRanges(start, end = end)))
  gr <- fixGR(gr)
  
  # Check for minimum region count
  if (length(gr) < min_region_hits) {
    warning("[enrichModule] Too few regions (", length(gr), ") for enrichment")
    return(NULL)
  }
  
  # Run local GREAT
  if (verbose) message("[enrichModule] Running local GREAT via rGREAT")
  job <- rGREAT::great(gr, ontologies, genome)
  results <- rGREAT::getEnrichmentTable(job)
  
  # Check for empty result
  if (nrow(results) == 0) {
    warning("[enrichModule] No terms passed p-value/hit filters")
    if (save) {
      if (verbose) message("[enrichModule] Writing empty output to ", file)
      writeLines("No enrichment terms passed filters.", file)
    }
    return(NULL)
  }
  
  # Post-process results
  results$p <- results$p_value
  results$adj_p <- stats::p.adjust(results$p, method = adjMethod)
  results$log_p <- -log10(results$p)
  results$log_adj_p <- -log10(results$adj_p)
  results$term <- results$description
  
  # Must come AFTER p is defined and BEFORE filtering
  if ("observed_region_hits" %in% colnames(results)) {
    results$region_hits <- results$observed_region_hits
  } else {
    stop("[enrichModule] Could not find 'observed_region_hits' column")
  }
  
  # Filtering
  results <- subset(results, region_hits >= min_region_hits & p < pvalue_threshold)
  if (nrow(results) == 0) {
    warning("[enrichModule] No terms passed p-value/hit filters")
    return(NULL)
  }
  
  # Final selection
  results <- results[order(results$p), ]
  results <- results[, c("id", "term", "region_hits", "fold_enrichment", "p",
                         "adj_p", "log_p", "log_adj_p")]
  
  
  
  # Save results
  if (save) {
    if (verbose) message("[enrichModule] Saving to ", file)
    write.table(results, file = file, sep = "\t", quote = FALSE, row.names = FALSE)
  }
  
  return(results)
}

run_all_GO_enrichments <- function(regions, modules, base_filename = "Module_GO_Enrichment", 
                                   save_combined = TRUE, verbose = TRUE) {
  # List of GO ontologies
  go_terms <- c("GO:BP", "GO:MF", "GO:CC")
  
  # Store results in a list
  results_list <- list()
  
  for (ont in go_terms) {
    if (verbose) message("\n--- Running enrichment for ", ont, " ---")
    
    # Define output filename
    out_file <- paste0(base_filename, "_", gsub(":", "_", ont), ".txt")
    
    # Run enrichModule
    res <- tryCatch({
      enrichModule(
        regions,
        module = modules,
        ontologies = ont,
        save = TRUE,
        file = out_file,
        verbose = verbose
      )
    }, error = function(e) {
      message("⚠️  Enrichment failed for ", ont, ": ", e$message)
      return(NULL)
    })
    
    # Store the result (if any)
    if (!is.null(res)) {
      res$Ontology <- ont
      results_list[[ont]] <- res
    }
  }
  
  # Optionally combine all results into one data frame
  if (save_combined && length(results_list) > 0) {
    combined <- do.call(rbind, results_list)
    combined_file <- paste0(base_filename, "_Combined.txt")
    write.table(combined, file = combined_file, sep = "\t", quote = FALSE, row.names = FALSE)
    if (verbose) message("\n✅ Combined results saved to: ", combined_file)
    return(combined)
  } else if (length(results_list) > 0) {
    return(results_list)
  } else {
    message("⚠️ No successful enrichments were returned.")
    return(NULL)
  }
}

