#Plot all relevant GO enrichments 
#Sig AP Only#
# Load required packages
library(dplyr)
library(ggplot2)
library(stringr)
library(tidytext) # for reorder_within and scale_y_reordered
library(rGREAT)
library(biomaRt)

# ==== CONFIGURATION ====
combined_file <- "SigWithAPModulesOnly_Combined.txt"
plot_out <- "SigWithAPModulesOnly_GO_Top15_Plot_withXlabels.pdf"

# ==== LOAD & CLEAN DATA ====
enrich_df <- read.delim(combined_file, stringsAsFactors = FALSE)

colnames(enrich_df) <- tolower(colnames(enrich_df))

if(!"term" %in% names(enrich_df)) {
  names(enrich_df)[names(enrich_df) == "name"] <- "term"
}
if(!"adj_p" %in% names(enrich_df)) {
  names(enrich_df)[names(enrich_df) %in% c("fdr", "adjp", "adj.p")] <- "adj_p"
}
if(!"fold_enrichment" %in% names(enrich_df)) {
  names(enrich_df)[names(enrich_df) %in% c("fold.enrichment", "enrichment")] <- "fold_enrichment"
}

# ==== FILTER TOP TERMS ====
top_terms <- enrich_df %>%
  group_by(ontology) %>%
  arrange(adj_p) %>%
  slice_head(n = 15) %>%
  ungroup()

# Wrap long term names for readability
top_terms$term <- str_wrap(top_terms$term, width = 55)

# ==== PLOT ====
p <- ggplot(top_terms, aes(
  x = fold_enrichment,
  y = reorder_within(term, fold_enrichment, ontology),
  fill = ontology
)) +
  geom_col(width = 0.7, show.legend = FALSE) +
  geom_text(
    aes(
      label = ifelse(adj_p < 0.05, "*", ""),
      x = fold_enrichment + 0.05 * max(fold_enrichment)
    ),
    fontface = "bold",
    size = 5.5,
    color = "black"
  ) +
  scale_y_reordered() +
  # use facet_grid to get per-panel x-axis labels
  facet_grid(rows = vars(ontology), scales = "free_y", switch = "x") +
  scale_fill_manual(values = c(
    "GO:BP" = "#FF6666",
    "GO:MF" = "#66CC99",
    "GO:CC" = "#6699FF"
  )) +
  labs(
    x = "Fold Enrichment",
    y = NULL,
    title = "Top 15 Enriched GO Terms per Ontology",
    subtitle = "Asterisks denote adj. p < 0.05"
  ) +
  theme_minimal(base_size = 14) +
  theme(
    axis.text.y = element_text(face = "bold", size = 10),
    axis.text.x = element_text(size = 12),
    plot.title = element_text(face = "bold", size = 18, hjust = 0.5),
    plot.subtitle = element_text(size = 13, hjust = 0.5),
    strip.text.y = element_text(face = "bold", size = 14, angle = 0),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 1),
    strip.placement = "outside",
    panel.spacing.y = unit(1.5, "lines"),
    axis.title.x = element_text(size = 14, face = "bold", margin = margin(t = 10))
  )

# ==== SAVE ====
ggsave(plot_out, plot = p, width = 9, height = 16)
message("✅ Plot saved to: ", plot_out)

