#GO term plotting#

#Male#
library(dplyr)
library(ggplot2)
library(stringr)
library(tidytext) # for reorder_within and scale_y_reordered
library(rGREAT)
library(biomaRt)


Male_FDRSig_GO

# ==== LOAD & CLEAN DATA ====
enrich_df <- Male_FDRSig_GO

colnames(enrich_df) <- tolower(colnames(enrich_df))

# ==== FILTER TOP TERMS ====
top_terms <- enrich_df %>%
  group_by('gene ontology') %>%
  arrange(hyper_adjp_bh) %>%
  slice_head(n = 15) %>%
  ungroup()

# Wrap long term names for readability
top_terms$name <- str_wrap(top_terms$name, width = 55)
colnames(top_terms)[colnames(top_terms) == "gene ontology"] <- "gene_ontology"

# ==== PLOT ====
p <- ggplot(top_terms, aes(
  x = hyper_fold_enrichment,
  y = reorder_within(name, hyper_adjp_bh, 'gene ontology'),
  fill = gene_ontology
)) +
  geom_col(width = 0.7, show.legend = FALSE) +
  geom_text(
    aes(
      label = ifelse(hyper_adjp_bh < 0.05, "*", ""),
      x = hyper_fold_enrichment + 0.05 * max(hyper_fold_enrichment)
    ),
    fontface = "bold",
    size = 5.5,
    color = "black"
  ) +
  scale_y_reordered() +
  # use facet_grid to get per-panel x-axis labels
  facet_grid(rows = vars(gene_ontology), scales = "free_y", switch = "x") +
  scale_fill_manual(values = c(
    "GO Biological Process" = "#FF6666",
    "GO Molecular Function" = "#66CC99",
    "GO Cellular Component" = "#6699FF"
  )) +
  labs(
    x = "Fold Enrichment",
    y = NULL,
    title = "Top 15 Enriched GO Terms per Ontology",
    subtitle = "Asterisks denote adj. p < 0.05"
  ) +
  theme_minimal(base_size = 14) +
  theme(
    axis.text.y = element_text(face = "bold", size = 10),
    axis.text.x = element_text(size = 12),
    plot.title = element_text(face = "bold", size = 18, hjust = 0.5),
    plot.subtitle = element_text(size = 13, hjust = 0.5),
    strip.text.y = element_text(face = "bold", size = 14, angle = 0),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 1),
    strip.placement = "outside",
    panel.spacing.y = unit(1.5, "lines"),
    axis.title.x = element_text(size = 14, face = "bold", margin = margin(t = 10))
  )

# ==== SAVE ====
ggsave("Top15GO_MalePRegFireAny.pdf", plot = p, width = 9, height = 16)
