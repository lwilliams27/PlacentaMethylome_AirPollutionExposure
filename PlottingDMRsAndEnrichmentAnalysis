#Plotting DMRs via Circos and Enrichment Analysis#

#Circos plots#
#Males#
setwd("~/Desktop/Lab_Work/Schmidt_Lab/Schmidt_MARBLESBSAFE_PWFE_Project/Logan_Placenta_PWFE_analysis/DMRs_PregFireAny")
dmr_data <- read.xlsx("Males_05Cutoff_PregFireAny_AdjGASeqGroup/DMRs/background_annotated.xlsx")
df <- data.frame(
  chr = dmr_data$chr,
  start = dmr_data$start,
  end = dmr_data$end,
  p_value = dmr_data$p.value,
  q_value = dmr_data$q.value,
  methylation_status = dmr_data$direction
)

# Ensure p_value is numeric
df$p_value <- as.numeric(as.character(df$p_value))

# Define colors based on methylation status
df$color <- ifelse(df$methylation_status == "Hypermethylated", "red",
                   ifelse(df$methylation_status == "Hypomethylated", "blue", "gray"))
# Adjust color for non-significant DMRs (p > 0.05)
df$color[df$p_value > 0.05] <- "gray"

# Create a new column for the y-axis values (inverted p-value for plot)
df$y_value <- -log10(df$p_value)

# Adjust the spacing between the chromosomes (gap.degree controls the angular gap between them)
circos.par(gap.degree = 2)  # Increase the angle between chromosomes, adjust this number

#Initialize ideogram#
circos.initializeWithIdeogram(species = "hg38", 
                              plotType = c("ideogram", "labels"),
                              chromosome.index = c("chr1", "chr2", "chr3", "chr4", "chr5", "chr6", "chr7",
                                                   "chr8", "chr9", "chr10", "chr11", "chr12", "chr13", "chr14",
                                                   "chr15", "chr16", "chr17", "chr18", "chr19", "chr20", "chr21",
                                                   "chr22", "chrX", "chrY"))

# Create the inner track for p-values
circos.trackPlotRegion(factors = df$chr, ylim = c(0, max(-log10(df$p_value), na.rm = TRUE)), 
                       bg.border = NA, track.height = 0.68)

# Add p-values as points on the inner track
circos.trackPoints(factors = df$chr, x = (df$start + df$end) / 2,
                   y = df$y_value, pch = 19, col = df$color, cex = 0.5)
# Add a y-axis
circos.yaxis(side = "left", labels.cex = 0.5)

# Clear the circos plot
circos.clear()

