#GO Enrichment comparisons between males and females# 
#Males#
#Setup
install.packages("readxl")   # if not already installed
library(readxl)
library(dplyr)

# Path to Excel file
file_path <- "Males_05Cutoff_PregFireAny_AdjGASeqGroup/Ontologies/GREAT_results.xlsx"

# Get sheet names
sheet_names <- excel_sheets(file_path)

# Loop through sheets, filter, and combine
combined_df <- lapply(sheet_names, function(sheet) {
  
  df <- read_excel(file_path, sheet = sheet)
  
  # Filter rows where Hyper_Adjp_BH < 0.05
  df_filtered <- df %>%
    filter(Hyper_Adjp_BH < 0.05) %>%
    mutate(`Gene Ontology` = sheet)
  
  return(df_filtered)
  
}) %>%
  bind_rows()

# View result
print(combined_df)

Male_FDRSig_GO <- combined_df

