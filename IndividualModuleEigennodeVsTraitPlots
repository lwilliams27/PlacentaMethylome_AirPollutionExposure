colData <- read.xlsx("sample_info.xlsx", rowNames = TRUE)
categorical_traits <- c("Diagnosis_ASD", "Sex", "PregFire_Any")
MEs <- modules$MEs
MEs <- MEs[rownames(MEs) %in% rownames(colData), ]

#loop it over everything to get all output properly#

#Establish module groups again#
#Define variables of interest#
MEtraitCor <- read.table("ME_Trait_Bicor_Correlation_Stats.txt", header = TRUE)
corrs <- MEtraitCor
df <- corrs
AP_traits <- c("PM25", "WF", "NonWF")
ND_traits <- c("Diagnosis", "MSL", "ADOS", "CBCL")

# --- tag traits ---
df$list_type <- ifelse(grepl(paste0("^(", paste(AP_traits, collapse="|"), ")"), df$trait), "A",
                       ifelse(grepl(paste0("^(", paste(ND_traits, collapse="|"), ")"), df$trait), "B", NA))

# --- keep only significant associations ---
sig_df <- df[df$p < 0.05, ]

library(dplyr)

# --- summarize significance per module ---
module_summary <- sig_df %>%
  group_by(module) %>%
  summarise(
    has_A = any(list_type == "A"),
    has_B = any(list_type == "B")
  )

# --- ensure all modules (including those with no sig. associations) are represented ---
all_modules <- unique(df$module)
module_summary <- full_join(
  data.frame(module = all_modules),
  module_summary,
  by = "module"
) %>%
  mutate(
    has_A = ifelse(is.na(has_A), FALSE, has_A),
    has_B = ifelse(is.na(has_B), FALSE, has_B)
  )

# --- identify modules in each category ---
ND_only_modules <- module_summary$module[module_summary$has_B & !module_summary$has_A]
AP_only_modules <- module_summary$module[module_summary$has_A & !module_summary$has_B]
Both_modules <- module_summary$module[module_summary$has_A & module_summary$has_B]
Neither_modules <- module_summary$module[!module_summary$has_A & !module_summary$has_B]

# Loop through each module
for (mod in Both_modules) {
  # Compute dynamic Y-axis range for this module
  y_values <- MEs[[mod]]
  y_min <- min(y_values, na.rm = TRUE)
  y_max <- max(y_values, na.rm = TRUE)
  y_range <- y_max - y_min
  y_margin <- 0.1 * y_range  # add 10% padding
  y_limits <- c(y_min - y_margin, y_max + y_margin)
  
  # Find significant traits for this module
  sig_traits <- MEtraitCor %>%
    filter(module == mod, p < 0.05) %>%
    pull(trait)
  
  # Loop through each trait
  for (trait in sig_traits) {
    y_data <- MEs[[mod]]
    x_data <- colData[[trait]]
    
    if (trait %in% categorical_traits) {
      # Use boxplot for categorical traits
      comethyl::plotMEtraitDot(
        MEs[[mod]],
        trait = x_data,
        traitCode = trait_codes[[trait]],
        colors = trait_colors[[trait]],
        ylim = y_limits,
        xlab = trait,
        ylab = paste(mod, "Module Eigengene"),
        file = paste0(mod, "_ME_", trait, "_Boxplot.pdf")
      )
    } else {
      # Use scatter plot for continuous traits
      plotMEtraitScatter2(
        MEs[[mod]],
        trait = x_data,
        ylim = y_limits,
        xlab = trait,
        ylab = paste(mod, "Module Eigengene"),
        file = paste0(mod, "_ME_", trait, "_Scatterplot.pdf")
      )
    }
  }
}

